<!DOCTYPE html>

<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>John Von Neumann — Arquiteto do Futuro</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Mono:wght@300;400;500&family=Crimson+Pro:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #0a0a0a;
    --paper: #f5f0e8;
    --gold: #c9a84c;
    --rust: #8b3a2a;
    --slate: #2c3e50;
    --fade: #d4cfc4;
    --red: #cc2200;
  }

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
background: var(–paper);
color: var(–ink);
font-family: ‘Crimson Pro’, serif;
font-size: 18px;
line-height: 1.7;
overflow-x: hidden;
}

/* NOISE TEXTURE OVERLAY */
body::before {
content: ‘’;
position: fixed;
inset: 0;
background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 256 256’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘noise’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.9’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23noise)’ opacity=‘0.04’/%3E%3C/svg%3E”);
pointer-events: none;
z-index: 999;
opacity: 0.3;
}

/* NAV */
nav {
position: fixed;
top: 0; left: 0; right: 0;
z-index: 100;
display: flex;
justify-content: space-between;
align-items: center;
padding: 1rem 3rem;
background: rgba(245, 240, 232, 0.92);
backdrop-filter: blur(8px);
border-bottom: 1px solid var(–fade);
}

nav .logo {
font-family: ‘DM Mono’, monospace;
font-size: 0.7rem;
letter-spacing: 0.25em;
text-transform: uppercase;
color: var(–rust);
}

nav ul {
list-style: none;
display: flex;
gap: 2rem;
}

nav ul a {
font-family: ‘DM Mono’, monospace;
font-size: 0.65rem;
letter-spacing: 0.2em;
text-transform: uppercase;
text-decoration: none;
color: var(–ink);
transition: color 0.2s;
}

nav ul a:hover { color: var(–rust); }

/* HERO */
#hero {
min-height: 100vh;
display: grid;
grid-template-columns: 1fr 1fr;
padding-top: 80px;
position: relative;
overflow: hidden;
}

.hero-left {
display: flex;
flex-direction: column;
justify-content: center;
padding: 6rem 4rem 6rem 6rem;
position: relative;
z-index: 2;
}

.hero-eyebrow {
font-family: ‘DM Mono’, monospace;
font-size: 0.65rem;
letter-spacing: 0.3em;
text-transform: uppercase;
color: var(–rust);
margin-bottom: 1.5rem;
opacity: 0;
animation: fadeUp 0.8s 0.2s forwards;
}

.hero-title {
font-family: ‘Playfair Display’, serif;
font-size: clamp(3rem, 6vw, 6rem);
font-weight: 900;
line-height: 0.95;
margin-bottom: 1rem;
opacity: 0;
animation: fadeUp 0.8s 0.4s forwards;
}

.hero-title .last-name {
color: var(–rust);
font-style: italic;
}

.hero-dates {
font-family: ‘DM Mono’, monospace;
font-size: 0.75rem;
letter-spacing: 0.15em;
color: var(–gold);
margin-bottom: 2.5rem;
opacity: 0;
animation: fadeUp 0.8s 0.55s forwards;
}

.hero-desc {
font-size: 1.1rem;
max-width: 420px;
color: #3a3530;
font-weight: 300;
font-style: italic;
opacity: 0;
animation: fadeUp 0.8s 0.7s forwards;
border-left: 3px solid var(–gold);
padding-left: 1.2rem;
}

.hero-scroll {
margin-top: 3rem;
font-family: ‘DM Mono’, monospace;
font-size: 0.6rem;
letter-spacing: 0.3em;
text-transform: uppercase;
color: var(–fade);
display: flex;
align-items: center;
gap: 0.8rem;
opacity: 0;
animation: fadeUp 0.8s 1s forwards;
}

.hero-scroll::before {
content: ‘’;
display: block;
width: 40px;
height: 1px;
background: var(–fade);
animation: scrollLine 2s infinite;
}

.hero-right {
position: relative;
display: flex;
align-items: center;
justify-content: center;
overflow: hidden;
}

.portrait-frame {
position: relative;
width: 380px;
height: 480px;
opacity: 0;
animation: fadeIn 1.2s 0.6s forwards;
}

.portrait-frame::before {
content: ‘’;
position: absolute;
inset: -12px;
border: 2px solid var(–gold);
opacity: 0.4;
z-index: 0;
}

.portrait-frame::after {
content: ‘’;
position: absolute;
inset: -6px;
border: 1px solid var(–rust);
opacity: 0.2;
z-index: 0;
}

.portrait-placeholder {
width: 100%;
height: 100%;
background: linear-gradient(135deg, #2c2520 0%, #1a1410 40%, #3a2f28 100%);
display: flex;
align-items: center;
justify-content: center;
flex-direction: column;
position: relative;
z-index: 1;
overflow: hidden;
}

.portrait-placeholder::before {
content: ‘’;
position: absolute;
inset: 0;
background: radial-gradient(ellipse at 50% 30%, rgba(201,168,76,0.15) 0%, transparent 70%);
}

.portrait-initials {
font-family: ‘Playfair Display’, serif;
font-size: 6rem;
font-weight: 900;
color: var(–gold);
opacity: 0.3;
letter-spacing: -0.05em;
line-height: 1;
}

.portrait-label {
font-family: ‘DM Mono’, monospace;
font-size: 0.6rem;
letter-spacing: 0.3em;
color: var(–fade);
opacity: 0.5;
margin-top: 0.5rem;
text-transform: uppercase;
}

/* Mathematical formula overlay */
.formula-bg {
position: absolute;
right: -40px;
top: 50%;
transform: translateY(-50%);
font-family: ‘Playfair Display’, serif;
font-size: 1rem;
color: var(–gold);
opacity: 0.06;
white-space: nowrap;
line-height: 2.2;
pointer-events: none;
writing-mode: vertical-rl;
font-style: italic;
}

/* DECORATIVE RULE */
.section-rule {
width: 60px;
height: 2px;
background: var(–gold);
margin: 0 auto 1rem;
}

/* TIMELINE */
#timeline {
padding: 8rem 0;
background: var(–ink);
color: var(–paper);
position: relative;
overflow: hidden;
}

#timeline::before {
content: ‘CRONOLOGIA’;
position: absolute;
top: 4rem;
left: -2rem;
font-family: ‘Playfair Display’, serif;
font-size: 14vw;
font-weight: 900;
color: white;
opacity: 0.02;
letter-spacing: -0.05em;
pointer-events: none;
white-space: nowrap;
}

.section-header {
text-align: center;
margin-bottom: 5rem;
}

.section-eyebrow {
font-family: ‘DM Mono’, monospace;
font-size: 0.65rem;
letter-spacing: 0.3em;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 0.8rem;
}

.section-title {
font-family: ‘Playfair Display’, serif;
font-size: clamp(2rem, 4vw, 3.5rem);
font-weight: 700;
line-height: 1.1;
}

.timeline-track {
max-width: 900px;
margin: 0 auto;
padding: 0 2rem;
position: relative;
}

.timeline-track::before {
content: ‘’;
position: absolute;
left: 50%;
top: 0; bottom: 0;
width: 1px;
background: linear-gradient(to bottom, transparent, var(–gold), transparent);
transform: translateX(-50%);
}

.tl-item {
display: grid;
grid-template-columns: 1fr 60px 1fr;
gap: 0;
margin-bottom: 3.5rem;
opacity: 0;
transform: translateY(30px);
transition: all 0.6s ease;
}

.tl-item.visible { opacity: 1; transform: none; }

.tl-item:nth-child(odd) .tl-content { grid-column: 1; text-align: right; }
.tl-item:nth-child(odd) .tl-empty { grid-column: 3; }
.tl-item:nth-child(even) .tl-content { grid-column: 3; text-align: left; }
.tl-item:nth-child(even) .tl-empty { grid-column: 1; }

.tl-dot {
grid-column: 2;
display: flex;
align-items: center;
justify-content: center;
position: relative;
z-index: 2;
}

.tl-dot-inner {
width: 14px;
height: 14px;
background: var(–gold);
border-radius: 50%;
border: 3px solid var(–ink);
box-shadow: 0 0 0 1px var(–gold);
}

.tl-year {
font-family: ‘DM Mono’, monospace;
font-size: 0.7rem;
color: var(–gold);
letter-spacing: 0.1em;
margin-bottom: 0.4rem;
}

.tl-event {
font-family: ‘Playfair Display’, serif;
font-size: 1.1rem;
font-weight: 700;
color: var(–paper);
margin-bottom: 0.4rem;
}

.tl-desc {
font-size: 0.9rem;
color: #8a8278;
font-style: italic;
}

/* CONTRIBUTIONS */
#contributions {
padding: 8rem 4rem;
max-width: 1200px;
margin: 0 auto;
}

.contrib-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 2px;
margin-top: 4rem;
background: var(–fade);
}

.contrib-card {
background: var(–paper);
padding: 2.5rem;
cursor: pointer;
transition: all 0.3s ease;
position: relative;
overflow: hidden;
}

.contrib-card::before {
content: ‘’;
position: absolute;
bottom: 0; left: 0; right: 0;
height: 3px;
background: var(–gold);
transform: scaleX(0);
transform-origin: left;
transition: transform 0.4s ease;
}

.contrib-card:hover::before { transform: scaleX(1); }

.contrib-card:hover {
background: #f0ebe0;
transform: translateY(-4px);
z-index: 1;
box-shadow: 0 12px 40px rgba(0,0,0,0.12);
}

.contrib-number {
font-family: ‘Playfair Display’, serif;
font-size: 3.5rem;
font-weight: 900;
color: var(–fade);
line-height: 1;
margin-bottom: 0.5rem;
}

.contrib-title {
font-family: ‘Playfair Display’, serif;
font-size: 1.3rem;
font-weight: 700;
color: var(–ink);
margin-bottom: 0.8rem;
}

.contrib-text {
font-size: 0.9rem;
color: #5a5550;
line-height: 1.6;
}

.contrib-tag {
display: inline-block;
margin-top: 1.2rem;
font-family: ‘DM Mono’, monospace;
font-size: 0.6rem;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–rust);
border: 1px solid var(–rust);
padding: 0.2rem 0.6rem;
}

/* ARCHITECTURE */
#architecture {
background: var(–slate);
color: var(–paper);
padding: 8rem 4rem;
position: relative;
overflow: hidden;
}

#architecture::after {
content: ‘01001000’;
position: absolute;
bottom: 2rem; right: 3rem;
font-family: ‘DM Mono’, monospace;
font-size: 4rem;
color: white;
opacity: 0.03;
letter-spacing: 0.2em;
}

.arch-container {
max-width: 900px;
margin: 0 auto;
}

.arch-diagram {
margin: 4rem auto;
position: relative;
}

.arch-boxes {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 2px;
margin-bottom: 2px;
}

.arch-box {
background: rgba(255,255,255,0.05);
border: 1px solid rgba(201,168,76,0.2);
padding: 2rem;
text-align: center;
transition: all 0.3s;
cursor: default;
}

.arch-box:hover {
background: rgba(201,168,76,0.1);
border-color: var(–gold);
}

.arch-box-main {
background: rgba(201,168,76,0.08);
border: 1px solid var(–gold);
padding: 2rem;
text-align: center;
grid-column: 1/-1;
}

.arch-box-title {
font-family: ‘DM Mono’, monospace;
font-size: 0.7rem;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 0.5rem;
}

.arch-box-desc {
font-size: 0.85rem;
color: #a09890;
font-style: italic;
}

.arch-arrows {
display: flex;
justify-content: space-around;
padding: 0.5rem 0;
}

.arch-arrow {
font-family: ‘DM Mono’, monospace;
font-size: 1.2rem;
color: var(–gold);
opacity: 0.5;
}

/* QUOTES */
#quotes {
padding: 8rem 4rem;
background: #f0ebe0;
}

.quotes-container {
max-width: 800px;
margin: 0 auto;
}

.quote-item {
position: relative;
padding: 3rem 3.5rem;
margin-bottom: 2rem;
background: var(–paper);
border-left: 4px solid var(–gold);
opacity: 0;
transform: translateX(-20px);
transition: all 0.7s ease;
}

.quote-item.visible { opacity: 1; transform: none; }

.quote-mark {
position: absolute;
top: -0.5rem;
left: 2rem;
font-family: ‘Playfair Display’, serif;
font-size: 5rem;
color: var(–gold);
line-height: 1;
opacity: 0.3;
}

.quote-text {
font-family: ‘Playfair Display’, serif;
font-size: 1.25rem;
font-style: italic;
color: var(–ink);
line-height: 1.6;
}

.quote-attr {
font-family: ‘DM Mono’, monospace;
font-size: 0.65rem;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–rust);
margin-top: 1.2rem;
}

/* LEGACY */
#legacy {
padding: 8rem 4rem;
background: var(–ink);
color: var(–paper);
text-align: center;
}

.legacy-grid {
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 2rem;
max-width: 1000px;
margin: 4rem auto 0;
}

.legacy-stat {
border-top: 1px solid rgba(201,168,76,0.3);
padding-top: 1.5rem;
}

.legacy-num {
font-family: ‘Playfair Display’, serif;
font-size: 3rem;
font-weight: 900;
color: var(–gold);
display: block;
}

.legacy-label {
font-family: ‘DM Mono’, monospace;
font-size: 0.6rem;
letter-spacing: 0.2em;
text-transform: uppercase;
color: #8a8278;
margin-top: 0.4rem;
}

.legacy-closing {
max-width: 600px;
margin: 5rem auto 0;
font-size: 1.1rem;
color: #8a8278;
font-style: italic;
line-height: 1.8;
}

/* FOOTER */
footer {
padding: 2rem 4rem;
background: #050505;
display: flex;
justify-content: space-between;
align-items: center;
}

footer p {
font-family: ‘DM Mono’, monospace;
font-size: 0.6rem;
letter-spacing: 0.15em;
color: #3a3530;
text-transform: uppercase;
}

/* ANIMATIONS */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(20px); }
to { opacity: 1; transform: none; }
}

@keyframes fadeIn {
from { opacity: 0; }
to { opacity: 1; }
}

@keyframes scrollLine {
0%, 100% { width: 40px; opacity: 1; }
50% { width: 20px; opacity: 0.3; }
}

@keyframes float {
0%, 100% { transform: translateY(0); }
50% { transform: translateY(-10px); }
}

/* INTERACTIVE TOOLTIP */
[data-tooltip] {
position: relative;
cursor: help;
border-bottom: 1px dashed var(–gold);
}

[data-tooltip]::after {
content: attr(data-tooltip);
position: absolute;
bottom: calc(100% + 8px);
left: 50%;
transform: translateX(-50%);
background: var(–ink);
color: var(–paper);
font-family: ‘DM Mono’, monospace;
font-size: 0.7rem;
padding: 0.5rem 0.8rem;
white-space: nowrap;
opacity: 0;
pointer-events: none;
transition: opacity 0.2s;
z-index: 10;
border: 1px solid var(–gold);
}

[data-tooltip]:hover::after { opacity: 1; }

/* SCROLL INDICATOR */
#progress-bar {
position: fixed;
top: 0; left: 0;
height: 2px;
background: var(–gold);
z-index: 200;
width: 0%;
transition: width 0.1s;
}

/* RESPONSIVE */
@media (max-width: 900px) {
#hero { grid-template-columns: 1fr; }
.hero-right { display: none; }
.hero-left { padding: 4rem 2rem; }
.contrib-grid { grid-template-columns: 1fr; }
.legacy-grid { grid-template-columns: repeat(2, 1fr); }
nav ul { display: none; }
.timeline-track::before { left: 20px; }
.tl-item { grid-template-columns: 40px 1fr; }
.tl-item:nth-child(odd) .tl-content,
.tl-item:nth-child(even) .tl-content { grid-column: 2; text-align: left; }
.tl-item .tl-empty { display: none; }
.tl-dot { grid-column: 1; }
}
</style>

</head>
